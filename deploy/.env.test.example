# Compose project name（用于卷/网络隔离）
COMPOSE_PROJECT_NAME=osg_test
TEST_DEPENDENCY_MODE=shared

# Note:
# - test DB/Redis is the shared data service for dev + test environments
# - local dev backend should use the same credentials/host via deploy/.env.dev

# Common
TZ=Asia/Shanghai
SPRING_PROFILES_ACTIVE=druid,docker
MYSQL_DATABASE=ry-vue
MYSQL_APP_USER=ruoyi
RUOYI_PROFILE=/data/ruoyi/uploadPath
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://backend:8080
E2E_API_PROXY_TARGET=http://backend:8080

# Shared remote dependencies (backend container reaches host-published dev deps)
MYSQL_SHARED_HOST=host.docker.internal
MYSQL_SHARED_PORT=23306
REDIS_SHARED_HOST=host.docker.internal
REDIS_SHARED_PORT=26379

# Test credentials（允许明文）
MYSQL_ROOT_PASSWORD=root123456
MYSQL_APP_PASSWORD=app123456
REDIS_PASSWORD=redis123456
JWT_SECRET=test-jwt-secret-change-me

# Test SMTP / delivery evidence
SPRING_MAIL_HOST=smtp.test.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=osg-test-mailer@example.com
SPRING_MAIL_PASSWORD=replace-with-real-test-smtp-password
SPRING_MAIL_FROM=noreply-test@osg.local
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_SMTP_SSL_ENABLE=false
PASSWORD_RESET_MAILBOX=qa+password-reset-test@osg.local
PASSWORD_RESET_PROVIDER_LOG_PATH=/data/ruoyi/uploadPath/audit/password-reset-mailbox.log
E2E_RESET_EMAIL=replace-with-real-registered-test-email@example.com

# Host ports (test stack only exposes backend + frontends)
BACKEND_PORT=28080
STUDENT_PORT=3001
MENTOR_PORT=3002
LEAD_MENTOR_PORT=3003
ASSISTANT_PORT=3004
ADMIN_PORT=3005
