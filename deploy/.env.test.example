# Compose project name（用于卷/网络隔离）
COMPOSE_PROJECT_NAME=osg_test

# Note:
# - test DB/Redis is the shared data service for dev + test environments
# - local dev backend should use the same credentials/host via deploy/.env.dev

# Common
TZ=Asia/Shanghai
SPRING_PROFILES_ACTIVE=druid,docker
MYSQL_DATABASE=ry-vue
MYSQL_APP_USER=ruoyi
RUOYI_PROFILE=/data/ruoyi/uploadPath
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://backend:8080
E2E_API_PROXY_TARGET=http://backend:8080

# Test credentials（允许明文）
MYSQL_ROOT_PASSWORD=root123456
MYSQL_APP_PASSWORD=app123456
REDIS_PASSWORD=redis123456
JWT_SECRET=test-jwt-secret-change-me

# Host ports
MYSQL_PORT=23306
REDIS_PORT=26379
BACKEND_PORT=28080
STUDENT_PORT=3001
MENTOR_PORT=3002
LEAD_MENTOR_PORT=3003
ASSISTANT_PORT=3004
ADMIN_PORT=3005
