# Compose project name（用于卷/网络隔离）
COMPOSE_PROJECT_NAME=osg_prod

# Common
TZ=Asia/Shanghai
SPRING_PROFILES_ACTIVE=druid,docker
MYSQL_DATABASE=ry-vue
MYSQL_APP_USER=ruoyi
RUOYI_PROFILE=/data/ruoyi/uploadPath

# Prod ports（默认仅开放 backend + frontends）
BACKEND_PORT=38080
STUDENT_PORT=13001
MENTOR_PORT=13002
LEAD_MENTOR_PORT=13003
ASSISTANT_PORT=13004
ADMIN_PORT=13005

# 注意：prod 禁止在 .env 中放置明文密码，统一走 deploy/secrets/*
# _FILE 映射由 compose.prod.yml 固化：
# - MYSQL_ROOT_PASSWORD_FILE=/run/secrets/mysql_root_password
# - MYSQL_APP_PASSWORD_FILE=/run/secrets/mysql_app_password
# - REDIS_PASSWORD_FILE=/run/secrets/redis_password
# - JWT_SECRET_FILE=/run/secrets/jwt_secret
