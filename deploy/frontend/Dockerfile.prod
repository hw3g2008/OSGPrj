FROM node:20-bullseye-slim AS build
ARG APP_PACKAGE=admin
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@9.15.9 --activate

COPY osg-frontend/ ./
RUN pnpm install --frozen-lockfile && pnpm --filter "@osg/${APP_PACKAGE}" exec vite build

FROM nginx:1.27-alpine
COPY deploy/frontend/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/packages/${APP_PACKAGE}/dist/ /usr/share/nginx/html/

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
