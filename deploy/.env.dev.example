# Local development runtime (app runs locally, shared DB/Redis with test env)
#
# Usage:
#   cp deploy/.env.dev.example deploy/.env.dev
#   # update credentials/host
#   bash bin/run-backend-dev.sh deploy/.env.dev

# Spring profile for local backend
SPRING_PROFILES_ACTIVE=druid

# Local backend port (keep 8080 unless occupied)
SERVER_PORT=8080

# Local upload path
RUOYI_PROFILE=./.local/uploadPath

# Shared Test DB service (same service used by remote test deployment)
# IMPORTANT: replace host/password with your real test environment values
# NOTE: value contains '&', must be quoted
SPRING_DATASOURCE_DRUID_MASTER_URL='jdbc:mysql://YOUR_TEST_DB_HOST:23306/ry-vue?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=GMT%2B8'
SPRING_DATASOURCE_DRUID_MASTER_USERNAME=ruoyi
SPRING_DATASOURCE_DRUID_MASTER_PASSWORD=change-me

# Shared Test Redis service
SPRING_DATA_REDIS_HOST=YOUR_TEST_REDIS_HOST
SPRING_DATA_REDIS_PORT=26379
SPRING_DATA_REDIS_PASSWORD=change-me

# Must match test environment JWT secret for cross-env token compatibility
TOKEN_SECRET=change-me

# Manual UI adjudication switch for final-gate/final-closure.
# Keep 0 by default. Flip to 1 only when UI visual failures are manually reviewed
# and downstream non-UI closure should continue with PARTIAL conclusion.
UI_VISUAL_ALLOW_DOWNSTREAM=0
UI_VISUAL_ADJUDICATION_REASON="manual review approved"
