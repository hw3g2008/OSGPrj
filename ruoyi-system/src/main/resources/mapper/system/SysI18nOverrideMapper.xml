<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysI18nOverrideMapper">

    <resultMap type="com.ruoyi.system.domain.SysI18nOverride" id="SysI18nOverrideResult">
        <result property="id"           column="id"           />
        <result property="lang"         column="lang"         />
        <result property="keyPath"      column="key_path"     />
        <result property="value"        column="value"        />
        <result property="scope"        column="scope"        />
        <result property="remark"       column="remark"       />
        <result property="createBy"     column="create_by"    />
        <result property="createTime"   column="create_time"  />
        <result property="updateBy"     column="update_by"    />
        <result property="updateTime"   column="update_time"  />
    </resultMap>

    <select id="selectByLang" resultMap="SysI18nOverrideResult">
        select id, lang, key_path, value, scope, remark,
               create_by, create_time, update_by, update_time
        from sys_i18n_override
        where lang = #{lang}
    </select>

</mapper>
