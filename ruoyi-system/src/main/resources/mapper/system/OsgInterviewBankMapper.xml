<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.OsgInterviewBankMapper">

    <resultMap id="OsgInterviewBankResult" type="OsgInterviewBank">
        <id property="bankId" column="bank_id"/>
        <result property="recordType" column="record_type"/>
        <result property="interviewBankName" column="interview_bank_name"/>
        <result property="interviewStage" column="interview_stage"/>
        <result property="interviewType" column="interview_type"/>
        <result property="industryName" column="industry_name"/>
        <result property="questionCount" column="question_count"/>
        <result property="status" column="status"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="applicationCode" column="application_code"/>
        <result property="studentName" column="student_name"/>
        <result property="appliedPosition" column="applied_position"/>
        <result property="applicationTime" column="application_time"/>
        <result property="applicationSource" column="application_source"/>
        <result property="pendingFlag" column="pending_flag"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectInterviewBankColumns">
        bank_id,
        record_type,
        interview_bank_name,
        interview_stage,
        interview_type,
        industry_name,
        question_count,
        status,
        updated_at,
        application_code,
        student_name,
        applied_position,
        application_time,
        application_source,
        pending_flag,
        create_by,
        create_time,
        update_by,
        update_time,
        remark
    </sql>

    <select id="selectInterviewBankList" parameterType="OsgInterviewBank" resultMap="OsgInterviewBankResult">
        select
        <include refid="selectInterviewBankColumns"/>
        from osg_interview_bank
        <where>
            record_type = 'bank'
            <if test="keyword != null and keyword != ''">
                and (
                    interview_bank_name like concat('%', #{keyword}, '%')
                    or industry_name like concat('%', #{keyword}, '%')
                )
            </if>
            <if test="interviewStage != null and interviewStage != ''">
                and interview_stage = #{interviewStage}
            </if>
            <if test="interviewType != null and interviewType != ''">
                and interview_type = #{interviewType}
            </if>
            <if test="industryName != null and industryName != ''">
                and industry_name = #{industryName}
            </if>
        </where>
        order by bank_id asc
    </select>

    <select id="selectInterviewBankApplicationList" parameterType="OsgInterviewBank" resultMap="OsgInterviewBankResult">
        select
        <include refid="selectInterviewBankColumns"/>
        from osg_interview_bank
        <where>
            record_type = 'application'
            <if test="keyword != null and keyword != ''">
                and (
                    student_name like concat('%', #{keyword}, '%')
                    or applied_position like concat('%', #{keyword}, '%')
                )
            </if>
        </where>
        order by bank_id asc
    </select>

    <select id="selectInterviewBankPendingCount" resultType="int">
        select count(1)
        from osg_interview_bank
        where record_type = 'application'
          and pending_flag = '1'
    </select>

    <select id="selectInterviewBankByBankId" parameterType="Long" resultMap="OsgInterviewBankResult">
        select
        <include refid="selectInterviewBankColumns"/>
        from osg_interview_bank
        where bank_id = #{bankId}
    </select>

    <insert id="insertInterviewBank" parameterType="OsgInterviewBank" useGeneratedKeys="true" keyProperty="bankId">
        insert into osg_interview_bank (
            record_type,
            interview_bank_name,
            interview_stage,
            interview_type,
            industry_name,
            question_count,
            status,
            updated_at,
            pending_flag,
            create_by,
            create_time,
            update_by,
            update_time,
            remark
        ) values (
            #{recordType},
            #{interviewBankName},
            #{interviewStage},
            #{interviewType},
            #{industryName},
            #{questionCount},
            #{status},
            sysdate(),
            #{pendingFlag},
            #{createBy},
            sysdate(),
            #{updateBy},
            sysdate(),
            #{remark}
        )
    </insert>

    <update id="updateInterviewBank" parameterType="OsgInterviewBank">
        update osg_interview_bank
        <set>
            <if test="interviewBankName != null and interviewBankName != ''">interview_bank_name = #{interviewBankName},</if>
            <if test="interviewStage != null and interviewStage != ''">interview_stage = #{interviewStage},</if>
            <if test="interviewType != null and interviewType != ''">interview_type = #{interviewType},</if>
            <if test="industryName != null and industryName != ''">industry_name = #{industryName},</if>
            <if test="questionCount != null">question_count = #{questionCount},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            updated_at = sysdate(),
            update_time = sysdate()
        </set>
        where bank_id = #{bankId}
    </update>

</mapper>
