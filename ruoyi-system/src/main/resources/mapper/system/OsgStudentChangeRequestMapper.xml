<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.OsgStudentChangeRequestMapper">

    <resultMap id="OsgStudentChangeRequestResult" type="OsgStudentChangeRequest">
        <id property="requestId" column="request_id"/>
        <result property="studentId" column="student_id"/>
        <result property="changeType" column="change_type"/>
        <result property="fieldKey" column="field_key"/>
        <result property="fieldLabel" column="field_label"/>
        <result property="beforeValue" column="before_value"/>
        <result property="afterValue" column="after_value"/>
        <result property="status" column="status"/>
        <result property="reviewer" column="reviewer"/>
        <result property="reviewedAt" column="reviewed_at"/>
        <result property="requestedBy" column="requested_by"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectChangeRequestColumns">
        select request_id, student_id, change_type, field_key, field_label, before_value, after_value,
               status, reviewer, reviewed_at, requested_by, create_by, create_time, update_by, update_time, remark
        from osg_student_change_request
    </sql>

    <select id="selectChangeRequestById" parameterType="Long" resultMap="OsgStudentChangeRequestResult">
        <include refid="selectChangeRequestColumns"/>
        where request_id = #{requestId}
    </select>

    <select id="selectChangeRequestList" parameterType="OsgStudentChangeRequest" resultMap="OsgStudentChangeRequestResult">
        <include refid="selectChangeRequestColumns"/>
        <where>
            <if test="requestId != null">
                and request_id = #{requestId}
            </if>
            <if test="studentId != null">
                and student_id = #{studentId}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
            <if test="changeType != null and changeType != ''">
                and change_type = #{changeType}
            </if>
        </where>
        order by create_time desc, request_id desc
    </select>

    <insert id="insertChangeRequest" parameterType="OsgStudentChangeRequest" useGeneratedKeys="true" keyProperty="requestId">
        insert into osg_student_change_request
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="studentId != null">student_id,</if>
            <if test="changeType != null and changeType != ''">change_type,</if>
            <if test="fieldKey != null and fieldKey != ''">field_key,</if>
            <if test="fieldLabel != null and fieldLabel != ''">field_label,</if>
            <if test="beforeValue != null">before_value,</if>
            <if test="afterValue != null">after_value,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="reviewer != null and reviewer != ''">reviewer,</if>
            <if test="reviewedAt != null">reviewed_at,</if>
            <if test="requestedBy != null and requestedBy != ''">requested_by,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            update_time,
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="studentId != null">#{studentId},</if>
            <if test="changeType != null and changeType != ''">#{changeType},</if>
            <if test="fieldKey != null and fieldKey != ''">#{fieldKey},</if>
            <if test="fieldLabel != null and fieldLabel != ''">#{fieldLabel},</if>
            <if test="beforeValue != null">#{beforeValue},</if>
            <if test="afterValue != null">#{afterValue},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="reviewer != null and reviewer != ''">#{reviewer},</if>
            <if test="reviewedAt != null">#{reviewedAt},</if>
            <if test="requestedBy != null and requestedBy != ''">#{requestedBy},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            sysdate(),
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateChangeRequestReview" parameterType="OsgStudentChangeRequest">
        update osg_student_change_request
        <set>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="reviewer != null">reviewer = #{reviewer},</if>
            <if test="reviewedAt != null">reviewed_at = #{reviewedAt},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where request_id = #{requestId}
    </update>
</mapper>
