<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.OsgSimPracticeMapper">
    <resultMap type="com.ruoyi.system.domain.OsgSimPractice" id="Result">
        <id property="practiceId" column="practice_id"/>
        <result property="studentId" column="student_id"/>
        <result property="studentName" column="student_name"/>
        <result property="practiceType" column="practice_type"/>
        <result property="requestContent" column="request_content"/>
        <result property="status" column="status"/>
        <result property="mentorIds" column="mentor_ids"/>
        <result property="mentorNames" column="mentor_names"/>
        <result property="scheduledAt" column="scheduled_at"/>
        <result property="completedHours" column="completed_hours"/>
        <result property="feedbackRating" column="feedback_rating"/>
        <result property="feedbackSummary" column="feedback_summary"/>
        <result property="submittedAt" column="submitted_at"/>
        <result property="createTime" column="create_time"/>
        <result property="delFlag" column="del_flag"/>
    </resultMap>

    <select id="selectList" resultMap="Result">
        select * from osg_sim_practice where del_flag='0'
        <if test="currentMentorId != null">and FIND_IN_SET(#{currentMentorId}, mentor_ids)</if>
        <if test="practiceType != null and practiceType != ''">and practice_type=#{practiceType}</if>
        <if test="status != null and status != ''">and status=#{status}</if>
        order by create_time desc
    </select>

    <select id="selectById" resultMap="Result">
        select * from osg_sim_practice where practice_id=#{practiceId} and del_flag='0'
    </select>

    <update id="update">
        update osg_sim_practice
        <set>
            <if test="status != null">status=#{status},</if>
            update_time=sysdate()
        </set>
        where practice_id=#{practiceId}
    </update>
</mapper>
