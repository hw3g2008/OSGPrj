<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.OsgCoachingMapper">

    <resultMap id="OsgCoachingResult" type="OsgCoaching">
        <id property="coachingId" column="coaching_id"/>
        <result property="applicationId" column="application_id"/>
        <result property="studentId" column="student_id"/>
        <result property="mentorId" column="mentor_id"/>
        <result property="mentorName" column="mentor_name"/>
        <result property="mentorIds" column="mentor_ids"/>
        <result property="mentorNames" column="mentor_names"/>
        <result property="mentorBackground" column="mentor_background"/>
        <result property="status" column="status"/>
        <result property="totalHours" column="total_hours"/>
        <result property="feedbackSummary" column="feedback_summary"/>
        <result property="assignNote" column="assign_note"/>
        <result property="assignedAt" column="assigned_at"/>
        <result property="confirmedAt" column="confirmed_at"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectCoachingColumns">
        coaching_id,
        application_id,
        student_id,
        mentor_id,
        mentor_name,
        mentor_ids,
        mentor_names,
        mentor_background,
        status,
        total_hours,
        feedback_summary,
        assign_note,
        assigned_at,
        confirmed_at,
        create_by,
        create_time,
        update_by,
        update_time,
        remark
    </sql>

    <select id="selectCoachingByApplicationId" parameterType="Long" resultMap="OsgCoachingResult">
        select
        <include refid="selectCoachingColumns"/>
        from osg_coaching
        where application_id = #{applicationId}
    </select>

    <select id="selectCoachingList" parameterType="OsgCoaching" resultMap="OsgCoachingResult">
        select
        <include refid="selectCoachingColumns"/>
        from osg_coaching
        <where>
            <if test="applicationId != null">
                and application_id = #{applicationId}
            </if>
            <if test="studentId != null">
                and student_id = #{studentId}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by coaching_id desc
    </select>

    <insert id="insertCoaching" parameterType="OsgCoaching" useGeneratedKeys="true" keyProperty="coachingId">
        insert into osg_coaching (
            application_id,
            student_id,
            mentor_id,
            mentor_name,
            mentor_ids,
            mentor_names,
            mentor_background,
            status,
            total_hours,
            feedback_summary,
            assign_note,
            assigned_at,
            confirmed_at,
            create_by,
            create_time,
            update_by,
            update_time,
            remark
        ) values (
            #{applicationId},
            #{studentId},
            #{mentorId},
            #{mentorName},
            #{mentorIds},
            #{mentorNames},
            #{mentorBackground},
            #{status},
            #{totalHours},
            #{feedbackSummary},
            #{assignNote},
            #{assignedAt},
            #{confirmedAt},
            #{createBy},
            sysdate(),
            #{updateBy},
            sysdate(),
            #{remark}
        )
    </insert>

    <update id="updateCoaching" parameterType="OsgCoaching">
        update osg_coaching
        <set>
            <if test="mentorId != null">mentor_id = #{mentorId},</if>
            <if test="mentorName != null">mentor_name = #{mentorName},</if>
            <if test="mentorIds != null">mentor_ids = #{mentorIds},</if>
            <if test="mentorNames != null">mentor_names = #{mentorNames},</if>
            <if test="mentorBackground != null">mentor_background = #{mentorBackground},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="totalHours != null">total_hours = #{totalHours},</if>
            <if test="feedbackSummary != null">feedback_summary = #{feedbackSummary},</if>
            <if test="assignNote != null">assign_note = #{assignNote},</if>
            <if test="assignedAt != null">assigned_at = #{assignedAt},</if>
            <if test="confirmedAt != null">confirmed_at = #{confirmedAt},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where coaching_id = #{coachingId}
    </update>

</mapper>
